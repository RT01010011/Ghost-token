# Copier vers .env (non versionné). Ne pas mettre de secrets dans .env.example.

PRIVATE_KEY=
BASESCAN_API_KEY=
ETHERSCAN_API_KEY=
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
HARDHAT_NODE_URL=

GHOST_PROTOCOL_V2=

# Obligatoires sur Base mainnet (8453) et Base Sepolia (84532) — pas de valeurs par défaut dans le script.
GHOST_WALLET_AIRDROP=
GHOST_WALLET_TREASURY_VESTING=
GHOST_WALLET_TEAM_VESTING=
GHOST_WALLET_REWARDS_TIMELOCK=
GHOST_WALLET_LIQUIDITY=
GHOST_PRESALE_ADMIN=

GHOST_PER_ETH_GHOST=212000
GHOST_PRESALE_SOFT_CAP_ETH=0
# Plafond total d’ETH pour toute la prévente (tous les acheteurs). Indépendant du plafond par wallet.
# Avec GHOST_PER_ETH_GHOST=212000 et 4,95 M GHOST en prévente, l’épuisement des jetons arrive vers ~23,35 ETH : le hard cap doit rester ≥ à ça (ex. 25 ou 10000), sinon la vente s’arrête avant d’écouler les GHOST.
GHOST_PRESALE_HARD_CAP_ETH=10000
# Maximum qu’une seule adresse peut contribuer (cumul sur la prévente).
GHOST_PRESALE_MAX_ETH_PER_WALLET=1
# Obligatoires sur Base mainnet / Sepolia (timestamps Unix explicites).
# FR — Ex. prévente : sam. 28 mars 2026 02:21 Europe/Paris (CET). Recalculer START/END si l’heure chaîne a dépassé START au moment du deploy.
# EN — Example presale: Sat 28 Mar 2026 02:21 Europe/Paris (CET). Recompute if chain time is past START when you deploy.
GHOST_PRESALE_START_UNIX=1774660860
GHOST_PRESALE_END_UNIX=1775265660
GHOST_REWARDS_LOCK_SECONDS=31536000
GHOST_ETH_SPLIT_BPS=
GHOST_PRESALE_BONUS_BPS=500
GHOST_BONUS_CREDENTIAL_DOMAIN=

# GhostPresaleWelcomeRegistry (100 GHOST) — déploiement **séparé** : npm run deploy:welcome-registry:base
# Ne pas relancer si deployed-addresses-ghost-welcome-registry.json existe déjà (anti-doublon).
# GHOST_WELCOME_CLAIM_OPENS_UNIX=       # optionnel — sinon fin de prévente (presale.endUnix du JSON ou endTime() on-chain)
# GHOST_WELCOME_CLAIM_OPENS_AFTER_END_SEC=0   # secondes après endTime (ex. 86400 = claim 24h après clôture prévente)
# GHOST_WELCOME_MAX_RECIPIENTS=3300
# GHOST_WELCOME_AMOUNT_GHOST=100
# GHOST_WELCOME_ADMIN=                  # sinon GHOST_PRESALE_ADMIN ou JSON écosystème
# GHOST_ECOSYSTEM_JSON=                 # chemin custom vers deployed-addresses-ghost-ecosystem.json
# GHOST_WELCOME_TOKEN= / _PRESALE= / _GHOST_V2=  # surcharges si pas de JSON
# GHOST_WELCOME_REGISTRY_ALREADY_DEPLOYED=0x…   # écrit seulement le JSON, aucun nouveau contrat

GHOST_SKIP_VERIFY=
GHOST_SKIP_DEPLOYER_SEPARATION_CHECKS=
GHOST_ALLOW_LEFTOVER_ON_DEPLOYER=

E2E_PRESALE_START_OFFSET_SEC=180
E2E_PRESALE_DURATION_SEC=604800
GHOST_E2E_ETH_RECEIVER=

LOCAL_PRESALE_START_OFFSET_SEC=90
