# Copier vers .env (non versionné). Ne pas mettre de secrets dans .env.example.

PRIVATE_KEY=
BASESCAN_API_KEY=
ETHERSCAN_API_KEY=
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
HARDHAT_NODE_URL=

GHOST_PROTOCOL_V2=

# Obligatoires sur Base mainnet (8453) et Base Sepolia (84532) — pas de valeurs par défaut dans le script.
GHOST_WALLET_AIRDROP=
GHOST_WALLET_TREASURY_VESTING=
GHOST_WALLET_TEAM_VESTING=
GHOST_WALLET_REWARDS_TIMELOCK=
GHOST_WALLET_LIQUIDITY=
GHOST_PRESALE_ADMIN=

GHOST_PER_ETH_GHOST=212000
GHOST_PRESALE_SOFT_CAP_ETH=0
GHOST_PRESALE_HARD_CAP_ETH=10000
GHOST_PRESALE_MAX_ETH_PER_WALLET=1
# Obligatoires sur Base mainnet / Sepolia (timestamps Unix explicites).
GHOST_PRESALE_START_UNIX=
GHOST_PRESALE_END_UNIX=
GHOST_REWARDS_LOCK_SECONDS=31536000
GHOST_ETH_SPLIT_BPS=
GHOST_PRESALE_BONUS_BPS=500
GHOST_BONUS_CREDENTIAL_DOMAIN=

GHOST_SKIP_VERIFY=
GHOST_SKIP_DEPLOYER_SEPARATION_CHECKS=
GHOST_ALLOW_LEFTOVER_ON_DEPLOYER=

E2E_PRESALE_START_OFFSET_SEC=180
E2E_PRESALE_DURATION_SEC=604800
GHOST_E2E_ETH_RECEIVER=

LOCAL_PRESALE_START_OFFSET_SEC=90
