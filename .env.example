# Copier vers .env (non versionné). Ne pas mettre de secrets dans .env.example.

PRIVATE_KEY=
BASESCAN_API_KEY=
ETHERSCAN_API_KEY=
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
HARDHAT_NODE_URL=

GHOST_PROTOCOL_V2=

# Obligatoires sur Base mainnet (8453) et Base Sepolia (84532) — pas de valeurs par défaut dans le script.
GHOST_WALLET_AIRDROP=
GHOST_WALLET_TREASURY_VESTING=
GHOST_WALLET_TEAM_VESTING=
GHOST_WALLET_REWARDS_TIMELOCK=
GHOST_WALLET_LIQUIDITY=
GHOST_PRESALE_ADMIN=

GHOST_PER_ETH_GHOST=212000
GHOST_PRESALE_SOFT_CAP_ETH=0
# Plafond total d’ETH pour toute la prévente (tous les acheteurs). Indépendant du plafond par wallet.
# Avec GHOST_PER_ETH_GHOST=212000 et 4,95 M GHOST en prévente, l’épuisement des jetons arrive vers ~23,35 ETH : le hard cap doit rester ≥ à ça (ex. 25 ou 10000), sinon la vente s’arrête avant d’écouler les GHOST.
GHOST_PRESALE_HARD_CAP_ETH=10000
# Maximum qu’une seule adresse peut contribuer (cumul sur la prévente).
GHOST_PRESALE_MAX_ETH_PER_WALLET=1
# Obligatoires sur Base mainnet / Sepolia (timestamps Unix explicites).
# FR — Prévente cible mainnet : ven. 27 mars 2026 02:10 Europe/Paris (CET). Timestamps Unix officiels (obligatoires sur Base mainnet / Sepolia si pas mode auto) :
# EN — Mainnet presale: Fri 27 Mar 2026 02:10 Europe/Paris (CET). Official Unix timestamps (required on Base mainnet/Sepolia unless using auto mode):
GHOST_PRESALE_START_UNIX=1774573800
GHOST_PRESALE_END_UNIX=1775178600
GHOST_REWARDS_LOCK_SECONDS=31536000
GHOST_ETH_SPLIT_BPS=
GHOST_PRESALE_BONUS_BPS=500
GHOST_BONUS_CREDENTIAL_DOMAIN=

GHOST_SKIP_VERIFY=
GHOST_SKIP_DEPLOYER_SEPARATION_CHECKS=
GHOST_ALLOW_LEFTOVER_ON_DEPLOYER=

E2E_PRESALE_START_OFFSET_SEC=180
E2E_PRESALE_DURATION_SEC=604800
GHOST_E2E_ETH_RECEIVER=

LOCAL_PRESALE_START_OFFSET_SEC=90
